# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/slidant

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption (Fernet key for API keys)
FERNET_KEY=your-fernet-key-change-in-production

# App
APP_ENV=development
